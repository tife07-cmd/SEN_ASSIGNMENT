<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.TifeScienticCalculator" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_main</item>
        <item name="colorSecondary">@color/teal_accent</item>
        <item name="android:windowBackground">@color/paper_white</item>
        <item name="android:statusBarColor">@color/purple_main</item>
    </style>

    <style name="Widget.TifeCalculator.Button" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:layout_margin">@dimen/button_margin</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.TifeCalculator.Button.Accent" parent="Widget.TifeCalculator.Button">
        <item name="backgroundTint">@color/teal_accent</item>
        <item name="android:textColor">@color/purple_main</item>
    </style>

    <style name="Widget.TifeCalculator.Button.Main" parent="Widget.TifeCalculator.Button">
        <item name="backgroundTint">@color/purple_main</item>
        <item name="android:textColor">@color/white</item>
    </style>

</resources>
