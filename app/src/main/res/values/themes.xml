<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.TifeScienticCalculator" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/on_accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/ink_black</item>
        <item name="android:colorBackground">@color/paper_white</item>
        <item name="android:windowBackground">@color/paper_white</item>
        <item name="android:statusBarColor">@color/paper_white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Widget.TifeCalculator.Button" parent="Widget.Material3.Button.TonalButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:layout_margin">@dimen/button_margin</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size_key</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">0dp</item>
        <item name="cornerRadius">@dimen/key_radius</item>
    </style>

    <style name="Widget.TifeCalculator.Button.Main" parent="Widget.TifeCalculator.Button">
        <item name="backgroundTint">@color/key</item>
        <item name="android:textColor">@color/ink_black</item>
    </style>

    <style name="Widget.TifeCalculator.Button.Accent" parent="Widget.TifeCalculator.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/on_accent</item>
    </style>

    <style name="Widget.TifeCalculator.Function" parent="Widget.TifeCalculator.Button">
        <item name="backgroundTint">@color/surface</item>
        <item name="android:textColor">@color/accent</item>
        <item name="strokeColor">@color/hairline</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textSize">16sp</item>
    </style>

</resources>
