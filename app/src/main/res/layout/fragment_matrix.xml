<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paper_white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/matrix_size"
                android:textColor="@color/ink_black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button android:id="@+id/btnSize2" style="@style/Widget.TifeCalculator.Function" android:text="2" android:minWidth="48dp" android:layout_width="wrap_content" android:layout_height="44dp" />
            <Button android:id="@+id/btnSize3" style="@style/Widget.TifeCalculator.Function" android:text="3" android:minWidth="48dp" android:layout_width="wrap_content" android:layout_height="44dp" />
            <Button android:id="@+id/btnSize4" style="@style/Widget.TifeCalculator.Function" android:text="4" android:minWidth="48dp" android:layout_width="wrap_content" android:layout_height="44dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/matrix_a"
            android:textColor="@color/ink_muted"
            android:textSize="14sp" />

        <GridLayout
            android:id="@+id/gridA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/matrix_b"
            android:textColor="@color/ink_muted"
            android:textSize="14sp" />

        <GridLayout
            android:id="@+id/gridB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="3">

            <Button android:id="@+id/btnMatAdd" style="@style/Widget.TifeCalculator.Function" android:text="@string/matrix_add" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="48dp" />
            <Button android:id="@+id/btnMatSub" style="@style/Widget.TifeCalculator.Function" android:text="@string/matrix_sub" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="48dp" />
            <Button android:id="@+id/btnMatMul" style="@style/Widget.TifeCalculator.Function" android:text="@string/matrix_mul" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="48dp" />
            <Button android:id="@+id/btnMatDet" style="@style/Widget.TifeCalculator.Function" android:text="@string/matrix_det" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="48dp" />
            <Button android:id="@+id/btnMatInv" style="@style/Widget.TifeCalculator.Function" android:text="@string/matrix_inv" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="48dp" />
            <Button android:id="@+id/btnMatTrans" style="@style/Widget.TifeCalculator.Function" android:text="@string/matrix_transpose" android:layout_columnWeight="1" android:layout_width="0dp" android:layout_height="48dp" />
        </GridLayout>

        <TextView
            android:id="@+id/tvMatrixOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/surface"
            android:fontFamily="monospace"
            android:padding="16dp"
            android:text="@string/result_placeholder"
            android:textColor="@color/ink_black"
            android:textSize="16sp" />
    </LinearLayout>
</ScrollView>
